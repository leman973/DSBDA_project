# Docker Environment Variables
# Copy this file to .env and customize for your deployment

# JWT Secret Key (REQUIRED - Change in production!)
# Generate a secure random string, at least 32 characters
SECRET_KEY=super-secret-key-change-this-in-production-min-32-chars

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dsbda_db

# Ollama URL (for Docker, use host.docker.internal)
OLLAMA_URL=http://host.docker.internal:11434

# Backend Configuration
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/dsbda_db
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=http://localhost:5173,http://localhost:80
