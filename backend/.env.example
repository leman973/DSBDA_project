# Gemini Configuration
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Database Configuration
# For local development without Docker:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dsbda_db

# For Docker deployment:
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/dsbda_db

# JWT Authentication
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Configuration
# Host and port for the FastAPI server
API_HOST=0.0.0.0
API_PORT=8000

# Upload Configuration (in bytes)
# Max file size: 50MB default
MAX_UPLOAD_SIZE=52428800

# Max rows to process in memory
MAX_ROWS_IN_MEMORY=100000
